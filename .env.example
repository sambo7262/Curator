# Curator Phase-1 environment template. Copy to `.env` on the NAS and fill in secrets.
# The real .env is gitignored — NEVER commit it. chmod 600 .env on the NAS.

# ---- PIA / VPN (OpenVPN — gluetun's native PIA path) ----
PIA_USER=                          # PIA OpenVPN username (p-number style login)
PIA_PASSWORD=                      # PIA OpenVPN password
PIA_PF_REGION="CA Vancouver"       # quoted: value has a space (Compose strips quotes; keeps shell-source clean).
                                   # PF-capable, west-coast (lowest latency for SoCal of the CA regions).
                                   # US is NEVER valid — 0/54 US regions support port forwarding.

# ---- Networking ----
SYNOBRIDGE_CIDR=172.20.0.0/16      # owner-confirmed synobridge subnet (gateway 172.20.0.1)

# ---- gluetun control-server auth ----
GLUETUN_API_KEY=                   # generate: docker run --rm qmcgaw/gluetun genkey

# ---- slskd ----
SLSKD_API_KEY=                     # slskd's own REST API key (Curator uses it from Phase 2 on)
                                   # format: role=...;cidr=...;<16-255 char secret>
                                   # MUST be quoted — the semicolons are shell separators, e.g.:
                                   # SLSKD_API_KEY="role=readwrite;cidr=172.20.0.0/16;<secret>"

# ---- Soulseek NETWORK account (slskd logs into the Soulseek network with these) ----
# There is NO separate signup — pick any username/password; a new username auto-registers
# on first connect (if it's already taken you'll get an error and just pick another).
SLSKD_SLSK_USERNAME=               # your chosen Soulseek username
SLSKD_SLSK_PASSWORD=               # your chosen Soulseek password

# ---- *arr API keys (Curator -> LAN reachability proof; Readarr is best-effort, Phase 2/3) ----
LIDARR_API_KEY=
READARR_API_KEY=

# ---- *arr / slskd URLs (OPTIONAL override) ----
# The compose defaults to the owner's NAS LAN IP (192.168.86.37) + published ports, because the
# *arr stack is not reachable from curator by synobridge container name in this homelab. Uncomment
# and edit ONLY if your hosts/ports differ; otherwise the compose defaults apply.
# SLSKD_URL=http://192.168.86.37:5030      # gluetun's published slskd port (NEVER http://slskd)
# LIDARR_URL=http://192.168.86.37:8686
# READARR_URL=http://192.168.86.37:8787

# ---- Phase 5 autonomy tunables (NOT secrets — all optional, sane defaults ship in the image) ----
# The daemon re-reads ACQ_ENABLED + the tunables each cycle, so most changes take effect on the next
# pass without a restart. See DEPLOY.md "Step 9 — Phase 5 setup" for the staged rollout + kill-switch.
ACQ_ENABLED=true                     # kill-switch: false halts ALL acquisition next cycle (no restart needed)
ACQ_DRY_RUN=false                    # true = search+gate+LOG only, ZERO side effects (the safe first rollout step)
MAX_CONCURRENT=3                     # steady-state cap on simultaneous acquisitions (start the rollout at 1, then 3)
ACQ_POLL_INTERVAL_SECONDS=21600      # daemon cycle cadence in seconds (21600 = 6h)
ACQ_GRACE_SECONDS=259200             # Usenet-politeness grace from discovered_at (259200 = 3 days)
ACQ_MAX_ATTEMPTS=3                   # genuine-failure attempts before an item -> permanently-unavailable
ACQ_DORMANT_SECONDS=2592000          # dormant re-check TTL for permanently-unavailable items (2592000 = 30 days)
# (Backoff between retries is fixed 1h->6h->24h; infra outages burn no attempt. No notification token here — D-13 Phase 6.)

# ---- SQLite ledger path (Phase 2; NOT a secret — it's a path) ----
# Lives on its OWN /db bind-mount, NOT under /data. The host dir /volume1/docker/curator/db
# must exist and be owned by PUID/PGID 1031:65536 before first run (WAL writes -wal/-shm sidecars).
# Must be on the local /volume1 volume — WAL is unsafe on NFS/CIFS network shares.
DB_PATH=/db/curator.sqlite

# ---- Docker Hub (image ref) ----
DOCKERHUB_USER=sambo7262           # image pulled is ${DOCKERHUB_USER}/curator

# ---- user / tz (owner-confirmed; NOT the typical Synology 1026/100) ----
PUID=1031
PGID=65536
TZ=America/Los_Angeles
