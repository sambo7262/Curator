# Curator Phase-1 environment template. Copy to `.env` on the NAS and fill in secrets.
# The real .env is gitignored — NEVER commit it. chmod 600 .env on the NAS.

# ---- PIA / VPN (OpenVPN — gluetun's native PIA path) ----
PIA_USER=                          # PIA OpenVPN username (p-number style login)
PIA_PASSWORD=                      # PIA OpenVPN password
PIA_PF_REGION="CA Vancouver"       # quoted: value has a space (Compose strips quotes; keeps shell-source clean).
                                   # PF-capable, west-coast (lowest latency for SoCal of the CA regions).
                                   # US is NEVER valid — 0/54 US regions support port forwarding.

# ---- Networking ----
SYNOBRIDGE_CIDR=172.20.0.0/16      # owner-confirmed synobridge subnet (gateway 172.20.0.1)

# ---- gluetun control-server auth ----
GLUETUN_API_KEY=                   # generate: docker run --rm qmcgaw/gluetun genkey

# ---- slskd ----
SLSKD_API_KEY=                     # slskd's own REST API key (Curator uses it from Phase 2 on)
                                   # format: role=...;cidr=...;<16-255 char secret>
                                   # MUST be quoted — the semicolons are shell separators, e.g.:
                                   # SLSKD_API_KEY="role=readwrite;cidr=172.20.0.0/16;<secret>"

# ---- Soulseek NETWORK account (slskd logs into the Soulseek network with these) ----
# There is NO separate signup — pick any username/password; a new username auto-registers
# on first connect (if it's already taken you'll get an error and just pick another).
SLSKD_SLSK_USERNAME=               # your chosen Soulseek username
SLSKD_SLSK_PASSWORD=               # your chosen Soulseek password

# ---- *arr API keys (Curator -> LAN reachability proof; Readarr is best-effort, Phase 2/3) ----
LIDARR_API_KEY=
READARR_API_KEY=

# ---- Docker Hub (image ref) ----
DOCKERHUB_USER=sambo7262           # image pulled is ${DOCKERHUB_USER}/curator

# ---- user / tz (owner-confirmed; NOT the typical Synology 1026/100) ----
PUID=1031
PGID=65536
TZ=America/Los_Angeles
